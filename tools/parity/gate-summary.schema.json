{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://khipu.dev/schemas/parity/gate-summary.schema.json",
  "title": "Parity Phase Gate Summary",
  "description": "Deterministic CI evidence for parity gates P0-P6.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow",
    "repository",
    "ref",
    "sha",
    "run_id",
    "run_attempt",
    "generated_at_utc",
    "gates",
    "overall_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "workflow": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "ref": {
      "type": "string",
      "minLength": 1
    },
    "sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "run_id": {
      "type": "integer",
      "minimum": 1
    },
    "run_attempt": {
      "type": "integer",
      "minimum": 1
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "gates": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "prefixItems": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/gate"
            },
            {
              "properties": {
                "phase": {
                  "const": "P0"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/gate"
            },
            {
              "properties": {
                "phase": {
                  "const": "P1"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/gate"
            },
            {
              "properties": {
                "phase": {
                  "const": "P2"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/gate"
            },
            {
              "properties": {
                "phase": {
                  "const": "P3"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/gate"
            },
            {
              "properties": {
                "phase": {
                  "const": "P4"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/gate"
            },
            {
              "properties": {
                "phase": {
                  "const": "P5"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/gate"
            },
            {
              "properties": {
                "phase": {
                  "const": "P6"
                }
              }
            }
          ]
        }
      ],
      "items": false
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed"
      ]
    }
  },
  "$defs": {
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "gate_id",
        "status",
        "blocked_by",
        "description",
        "evidence",
        "duration_ms",
        "evidence_collected_at_utc"
      ],
      "properties": {
        "phase": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "P4",
            "P5",
            "P6"
          ]
        },
        "gate_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "blocked",
            "not_applicable"
          ]
        },
        "blocked_by": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^\\[(PASS|FAIL|SKIP)\\] .+"
          }
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_collected_at_utc": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "blocked"
              }
            }
          },
          "then": {
            "properties": {
              "blocked_by": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "else": {
            "properties": {
              "blocked_by": {
                "type": "null"
              }
            }
          }
        }
      ]
    }
  }
}
